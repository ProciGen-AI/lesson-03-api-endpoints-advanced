# Cumulative .env example for the AI Engineering course (snapshot as of Lesson 2).
# Every variable any lab needs through this lesson is listed here. Copy this
# file to .env at the repo root and fill in real values:
#   cp .env.example .env

# AWS access key for the IAM user/role with bedrock:InvokeModel permission.
# Generate in IAM console → Users → Security credentials → "Create access key".
AWS_ACCESS_KEY_ID=your-access-key-id-here

# AWS secret access key paired with AWS_ACCESS_KEY_ID. Shown once at creation.
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here

# AWS region for Bedrock calls. us-east-1 has the broadest model availability;
# us-west-2 is the other common choice. Must match a region where you've been
# granted access to BEDROCK_MODEL_ID.
AWS_REGION=us-east-1

# Bedrock model ID for the default LLM call across labs.
# Find current IDs in the Bedrock console: Discover → Model catalog →
# filter by Amazon → click "Nova 2 Lite". Use the cross-region inference-profile
# ID (the `us.` one below), NOT the bare `amazon.nova-2-lite-v1:0`: Nova 2 Lite
# isn't callable in-region on-demand in us-east-1, so a profile prefix is
# required. (`eu.` / `jp.` / `global.` profiles exist for other regions.)
BEDROCK_MODEL_ID=us.amazon.nova-2-lite-v1:0          # fast, cheap reasoning model (course default)
# Nova 2 Pro is preview-only as of this writing — add it here once it's GA in your account.

# Google AI Studio API key. Used by Lesson 2 exercise 01 (raw HTTP) only —
# the "an LLM API is just an HTTP POST" example, which hits Gemini because its
# API-key auth is simpler than Bedrock's SigV4 signing. Get a key at:
#   https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Gemini model ID for exercise 01. Flash is fast and cheap.
GEMINI_MODEL_ID=gemini-3-flash-preview
